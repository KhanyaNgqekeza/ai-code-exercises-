EXERCISE 2.2

describe("calculateTaskScore - due date calculation", () => {

  // Helper: fixed "now" concept (avoids flaky tests)
  const BASE_TASK = {
    priority: "MEDIUM",
    status: "TODO",
    tags: [],
    updatedAt: new Date("2025-01-10T00:00:00Z")
  };

  test("adds +30 points for overdue tasks", () => {
    const task = {
      ...BASE_TASK,
      dueDate: new Date("2025-01-08T00:00:00Z") // 2 days overdue
    };

    const result = calculateTaskScore(task);

    // MEDIUM = 20 base + 30 overdue bonus
    expect(result).toBe(50);
  });

  test("adds +20 points for tasks due today", () => {
    const task = {
      ...BASE_TASK,
      dueDate: new Date("2025-01-10T00:00:00Z") // same day as updatedAt baseline
    };

    const result = calculateTaskScore(task);

    // 20 base + 20 today bonus
    expect(result).toBe(40);
  });

  test("adds +15 points for tasks due within 1-2 days", () => {
    const task = {
      ...BASE_TASK,
      dueDate: new Date("2025-01-11T00:00:00Z") // 1 day ahead
    };

    const result = calculateTaskScore(task);

    // 20 base + 15 near-term bonus
    expect(result).toBe(35);
  });

  test("adds +10 points for tasks due within 3-7 days", () => {
    const task = {
      ...BASE_TASK,
      dueDate: new Date("2025-01-15T00:00:00Z") // 5 days ahead
    };

    const result = calculateTaskScore(task);

    // 20 base + 10 weekly bonus
    expect(result).toBe(30);
  });

  test("does not apply due date bonus when dueDate is missing", () => {
    const task = {
      ...BASE_TASK
      // no dueDate
    };

    const result = calculateTaskScore(task);

    // Only base score applies
    expect(result).toBe(20);
  });

  test("does not crash when dueDate is invalid", () => {
    const task = {
      ...BASE_TASK,
      dueDate: "invalid-date"
    };

    const result = calculateTaskScore(task);

    // Should still return a number (base behavior safe handling expected)
    expect(typeof result).toBe("number");
  });

  test("correctly prioritizes overdue over all other ranges", () => {
    const task = {
      ...BASE_TASK,
      dueDate: new Date("2025-01-01T00:00:00Z") // very overdue
    };

    const result = calculateTaskScore(task);

    // 20 base + 30 overdue = strongest due-date boost
    expect(result).toBe(50);
  });

});


