      dueDate: new Date("2025-01-10"),
      updatedAt: new Date("2025-01-09")
    },
    {
      id: 3,
      priority: "MEDIUM",
      status: "DONE",
      tags: [],
      dueDate: new Date("2025-01-08"),
      updatedAt: new Date("2025-01-07")
    }
  ];

  // Run full pipeline
  const result = getTopPriorityTasks(tasks, 2);

  // 1. Should only return top 2 tasks
  expect(result.length).toBe(2);

  // 2. Highest priority task should be URGENT + critical tag
  expect(result[0].id).toBe(2);

  // 3. DONE task should be pushed down due to penalty
  expect(result.some(task => task.id === 3)).toBe(false);
});