/**
 * Constants for business rules and inventory management.
 */
const MINIMUM_REQUIRED_STOCK = 1; 

/**
 * Processes a customer's shopping cart against the available inventory.
 * Verifies stock levels, updates inventory, and calculates the total order price.
 * 
 * @param {Array<Object>} shoppingCart - List of items the user wants to buy. Each item requires 'id' and 'p' (price).
 * @param {Array<Object>} inventory - Current stock list. Each item requires 'id' and 'q' (quantity).
 * @param {number} requestedQuantity - The quantity to purchase for each item in the cart.
 * @returns {Object} An object containing the processed items and the total order cost.
 */
function processPurchaseOrder(shoppingCart, inventory, requestedQuantity) {
  const successfullyProcessedItems = [];
  let totalOrderCost = 0;

  for (const cartItem of shoppingCart) {
    const inventoryItem = findInventoryItem(inventory, cartItem.id);

    if (!inventoryItem) {
      console.log(`Item ${cartItem.id} not available in inventory`);
      continue;
    }

    const hasSufficientStock = inventoryItem.q >= requestedQuantity;

    if (hasSufficientStock) {
      successfullyProcessedItems.push(cartItem);
      totalOrderCost += cartItem.p * requestedQuantity;
      
      // Deduct purchased quantity from live inventory
      inventoryItem.q -= requestedQuantity;
    } else {
      console.log(`Item ${cartItem.id} is out of stock for the requested quantity (${requestedQuantity}).`);
    }
  }

  return {
    processedItems: successfullyProcessedItems,
    totalCost: totalOrderCost
  };
}

/**
 * Helper function to locate an item in the inventory by its ID.
 * 
 * @param {Array<Object>} inventory - The stock list to search through.
 * @param {string|number} itemId - The unique identifier of the item.
 * @returns {Object|null} The inventory item if found, otherwise null.
 */
function findInventoryItem(inventory, itemId) {
  return inventory.find(item => item.id === itemId) || null;
}
