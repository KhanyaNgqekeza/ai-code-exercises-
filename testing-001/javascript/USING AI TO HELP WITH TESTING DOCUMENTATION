🟩 Step 2: Minimal Implementation
function calculateTaskScore(task, currentUserId) {
  const weights = {
    LOW: 1,
    MEDIUM: 2,
    HIGH: 3,
    URGENT: 4
  };

  let score = (weights[task.priority] || 0) * 10;

  if (task.assignedTo === currentUserId) {
    score += 12;
  }

  return score;
}
🟦 Step 3: Refactor
function getBaseScore(task, weights) {
  return (weights[task.priority] || 0) * 10;
}

function getAssignedBonus(task, userId) {
  return task.assignedTo === userId ? 12 : 0;
}

function calculateTaskScore(task, userId) {
  const weights = { LOW: 1, MEDIUM: 2, HIGH: 3, URGENT: 4 };

  return getBaseScore(task, weights) + getAssignedBonus(task, userId);
}
