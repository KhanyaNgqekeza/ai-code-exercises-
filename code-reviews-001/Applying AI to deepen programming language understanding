class StandardShippingStrategy {
  calculate({ weight, length, width, height }, destinationCountry) {
    const rates = { USA: 2.5, Canada: 3.5, Mexico: 4.0 };
    const baseRate = rates[destinationCountry] ?? 4.5; 
    
    const baseCost = weight * baseRate;
    const volume = length * width * height;
    
    const hasDimensionalSurcharge = weight < 2 && volume > 1000;
    const surcharge = hasDimensionalSurcharge ? 5.0 : 0.0;

    return baseCost + surcharge;
  }
}

